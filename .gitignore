# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node/Hardhat
node_modules/
artifacts/
cache/
coverage/

# Environment
.env
.env.*

# Private keys and signatures
keys/*
!keys/.gitkeep
*.pem
*.key
*.sig

# Generated video and packages
data/input/*
!data/input/.gitkeep
data/segments/*
!data/segments/.gitkeep
data/packages/*
!data/packages/.gitkeep
data/tampered/*
!data/tampered/.gitkeep
data/anchor/*
!data/anchor/.gitkeep

# Reports generated by runs
reports/*
!reports/.gitkeep

# Local/editor files
.DS_Store
*.log
